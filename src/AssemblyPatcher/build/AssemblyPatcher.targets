<Project>
  <PropertyGroup>
    <AssemblyPatcher_TargetFramework Condition="'$(MSBuildRuntimeType)' == 'Core'">netstandard2.0</AssemblyPatcher_TargetFramework>
    <AssemblyPatcher_TargetFramework Condition="'$(MSBuildRuntimeType)' != 'Core'">net462</AssemblyPatcher_TargetFramework>
    <AssemblyPatcher_Assembly>$(MSBuildThisFileDirectory)../tools/$(AssemblyPatcher_TargetFramework)/AssemblyPatcher.dll</AssemblyPatcher_Assembly>
    <AssemblyPatcher_IntermediatePath>$(IntermediateOutputPath)/AssemblyPatcher</AssemblyPatcher_IntermediatePath>
    <AssemblyPatcher_ManifestFilePath>$(AssemblyPatcher_IntermediatePath)/AssemblyPatcher.manifest</AssemblyPatcher_ManifestFilePath>
    <AssemblyPatcher_ResolvedFilesManifestFilePath>$(AssemblyPatcher_IntermediatePath)/AssemblyPatcher.resolvedfiles.manifest</AssemblyPatcher_ResolvedFilesManifestFilePath>
  </PropertyGroup>

  <UsingTask AssemblyFile="$(AssemblyPatcher_Assembly)" TaskName="AssemblyPatcher.PatcherTask" />

  <Target Name="GetAssemblyPatcherReferencePaths"
          Inputs="$(MSBuildAllProjects)"
          Outputs="$(AssemblyPatcher_ManifestFilePath)"
          Returns="@(AssemblyPatcher_InputReferencePath);@(AssemblyPatcher_OutputReferencePath)">
    <ItemGroup>
      <AssemblyPatcher_ReferencePathJoin Include="@(ReferencePath)" AddInternalsVisibleTo="%(AddInternalsVisibleTo.Identity)" RemoveSealedFrom="%(RemoveSealedFrom.Identity)" AddVirtualTo="%(AddVirtualTo.Identity)" MakePublic="%(MakePublic.Identity)" />
      <AssemblyPatcher_InputReferencePath Include="@(AssemblyPatcher_ReferencePathJoin)" Condition=" '%(Filename)' == '%(AddInternalsVisibleTo)' Or '%(Filename)' == '%(RemoveSealedFrom)' Or '%(Filename)' == '%(AddVirtualTo)' Or '%(Filename)' == '%(MakePublic)' " />
      <AssemblyPatcher_ReferencePathJoin Remove="@(AssemblyPatcher_ReferencePathJoin)" />
      <AssemblyPatcher_OutputReferencePath Include="@(AssemblyPatcher_InputReferencePath->'$(AssemblyPatcher_IntermediatePath)/%(Filename)%(Extension)')" OriginalItemSpec="%(Identity)" />
    </ItemGroup>

    <WriteLinesToFile File="$(AssemblyPatcher_ManifestFilePath)" Lines="@(AssemblyPatcher_InputReferencePath)" WriteOnlyWhenDifferent="true" Overwrite="true" />
  </Target>

  <Target Name="PatchAssemblies"
          DependsOnTargets="GetAssemblyPatcherReferencePaths"
          AfterTargets="AfterResolveReferences"
          Inputs="@(AssemblyPatcher_InputReferencePath);$(AssemblyPatcher_ManifestFilePath)"
          Outputs="@(AssemblyPatcher_OutputReferencePath)"
          Returns="@(ReferencePath)">
    <PatcherTask SourceReferences="@(ReferencePath)"
                 AssemblyNames="@(AddInternalsVisibleTo)"
                 AttributeAssemblyNames="@(AddInternalsVisibleTo->'%(AssemblyName)')"
                 RemoveSealedFrom="@(RemoveSealedFrom)"
                 AddVirtualTo="@(AddVirtualTo)"
                 MakePublic="@(MakePublic)"
                 IntermediateOutputPath="$(AssemblyPatcher_IntermediatePath)" />
    <ItemGroup>
      <ReferencePath Include="@(AssemblyPatcher_OutputReferencePath)" />
      <ReferencePath Remove="@(AssemblyPatcher_OutputReferencePath->'%(OriginalItemSpec)')" />

      <ReferencePathWithRefAssemblies Include="@(AssemblyPatcher_OutputReferencePath)" />
      <ReferencePathWithRefAssemblies Remove="@(AssemblyPatcher_OutputReferencePath->'%(OriginalItemSpec)')" />

      <ReferenceDependencyPaths Include="@(AssemblyPatcher_OutputReferencePath)" />
      <ReferenceDependencyPaths Remove="@(AssemblyPatcher_OutputReferencePath->'%(OriginalItemSpec)')" />

      <ReferenceCopyLocalPaths Include="@(AssemblyPatcher_OutputReferencePath)" />
      <ReferenceCopyLocalPaths Remove="@(AssemblyPatcher_OutputReferencePath->'%(OriginalItemSpec)')" />
    </ItemGroup>
  </Target>

  <Target Name="GetAssemblyPatcherResolvedFiles"
          Inputs="$(MSBuildAllProjects)"
          Outputs="$(AssemblyPatcher_ResolvedFilesManifestFilePath)"
          Returns="@(AssemblyPatcher_InputResolvedFileToPublish);@(AssemblyPatcher_OutputResolvedFileToPublish)">
    <ItemGroup>
      <AssemblyPatcher_ResolvedFileToPublishJoin Include="@(ResolvedFileToPublish)" AddInternalsVisibleTo="%(AddInternalsVisibleTo.Identity)" RemoveSealedFrom="%(RemoveSealedFrom.Identity)" AddVirtualTo="%(AddVirtualTo.Identity)" MakePublic="%(MakePublic.Identity)" />
      <AssemblyPatcher_InputResolvedFileToPublish Include="@(AssemblyPatcher_ResolvedFileToPublishJoin)" Condition=" '%(Filename)' == '%(AddInternalsVisibleTo)' Or '%(Filename)' == '%(RemoveSealedFrom)' Or '%(Filename)' == '%(AddVirtualTo)' Or '%(Filename)' == '%(MakePublic)' " />
      <AssemblyPatcher_ResolvedFileToPublishJoin Remove="@(AssemblyPatcher_ResolvedFileToPublishJoin)" />
      <AssemblyPatcher_OutputResolvedFileToPublish Include="@(AssemblyPatcher_InputResolvedFileToPublish->'$(AssemblyPatcher_IntermediatePath)/%(Filename)%(Extension)')" OriginalItemSpec="%(Identity)" />
    </ItemGroup>

    <WriteLinesToFile File="$(AssemblyPatcher_ResolvedFilesManifestFilePath)" Lines="@(AssemblyPatcher_InputResolvedFileToPublish)" WriteOnlyWhenDifferent="true" Overwrite="true" />
  </Target>

  <Target Name="PatchPublishAssemblies"
          DependsOnTargets="PatchAssemblies;GetAssemblyPatcherResolvedFiles"
          AfterTargets="ComputeResolvedFilesToPublishList"
          BeforeTargets="_ComputeResolvedFilesToPublishTypes">
    <ItemGroup>
      <ResolvedFileToPublish Include="@(AssemblyPatcher_OutputResolvedFileToPublish)" />
      <ResolvedFileToPublish Remove="@(AssemblyPatcher_InputResolvedFileToPublish)" />
    </ItemGroup>
  </Target>

  <Target Name="AssemblyPatcherClean" AfterTargets="Clean">
    <ItemGroup>
      <AssemblyPatcher_Directory Include="$(AssemblyPatcher_IntermediatePath)" />
    </ItemGroup>
    <RemoveDir Directories="@(AssemblyPatcher_Directory)" />
  </Target>

</Project>
